# ─── Required ───────────────────────────────────────────────────────────────

# Postgres (Drizzle). Supabase → Settings → Database → URI (encode @ # in password as %40 %23).
# For `npm run db:push`, prefer the **direct** session URL (port 5432) if introspection hangs on the pooler (6543).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# Same Supabase project as the browser client (used for JWKS verification).
# JWKS URL used by the API: {SUPABASE_URL}/auth/v1/.well-known/jwks.json
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Credex email/password API (/auth/register, /auth/login) — HS256 signing.
JWT_SECRET=change-me-to-a-long-random-secret

# ─── Recommended ────────────────────────────────────────────────────────────

PORT=3000
FRONTEND_URL=http://localhost:5173

# ─── Resend (lead confirmation emails) ─────────────────────────────────────
# https://resend.com/api-keys — never commit real keys.
RESEND_API_KEY=
# Verified domain sender (required when NODE_ENV is production or test).
# Local dev: if unset, the API uses Resend's sandbox sender Credex <onboarding@resend.dev>.
RESEND_FROM=

# ─── Supabase JWT (JWKS) — optional overrides ────────────────────────────────
# Defaults match typical Supabase Auth access tokens (issuer …/auth/v1).
# Unset = use derived URLs from SUPABASE_URL only.

# Issuer must match JWT `iss` (usually https://YOUR_PROJECT_REF.supabase.co/auth/v1).
# SUPABASE_JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1

# If verification fails with a valid Supabase session token, try setting audience to match `aud`:
# SUPABASE_JWT_AUD=authenticated

# Full JWKS URL override (default: {SUPABASE_URL}/auth/v1/.well-known/jwks.json).
# SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json

# Only accept Supabase JWKS tokens (no Credex HS256 fallback). Use when all clients use Supabase Auth.
# SUPABASE_JWT_VERIFY_ONLY=true

# ─── Google Gemini (AI Studio) — summaries + insights ───────────────────────
# Create a key: https://aistudio.google.com/apikey  (server only; never VITE_*)
# GEMINI_API_KEY=
# Default model: gemini-2.5-flash (gemini-1.5-flash is retired on the API)
# GEMINI_MODEL=gemini-2.5-flash

# Never commit service-role keys or sbp_* tokens. Frontend: VITE_SUPABASE_PUBLISHABLE_KEY only.
